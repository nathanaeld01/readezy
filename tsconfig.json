{
    "compilerOptions": {
        "allowJs": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "strict": true,
        "isolatedModules": true,
        "target": "ESNext",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "noEmit": true,
        "paths": {
            "@/*": ["./frontend/*"],
            "ziggy-js": ["./vendor/tightenco/ziggy"]
        }
    },
    "include": [
        "frontend/**/*.tsx",
        "frontend/**/*.ts",
        "resources/**/*.tsx",
        "resources/**/*.ts",
        "**/*.config.js",
        "**/*.config.ts",
        "**/*.config.mjs",
        "vendor/tightenco/ziggy"
    ],
    "exclude": ["node_modules"]
}
